# Скопируй в .env и заполни значениями. .env в git не попадает.

# ---- Docker Compose ----
COMPOSE_PROJECT_NAME=football_dwh

# ---- Postgres (один инстанс: метаданные Airflow + DWH) ----
POSTGRES_USER=football
POSTGRES_PASSWORD=football
POSTGRES_AIRFLOW_DB=airflow
POSTGRES_DWH_DB=dwh
POSTGRES_PORT=5432

# ---- MinIO (raw lake) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- ClickHouse (data marts) ----
CLICKHOUSE_USER=football
CLICKHOUSE_PASSWORD=football
CLICKHOUSE_DB=dwh
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9009

# ---- Airflow ----
# Fernet key — сгенерируй своим:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_UID=50000
# Нестандартный порт — 8080 на Windows часто занят HP Smart / ApplicationWebServer.
AIRFLOW_WEBSERVER_PORT=18080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_FERNET_KEY=REPLACE_ME_WITH_GENERATED_FERNET_KEY
AIRFLOW_SECRET_KEY=REPLACE_ME_WITH_RANDOM_STRING

# ---- Superset ----
SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_SECRET_KEY=REPLACE_ME_WITH_RANDOM_STRING

# ---- Spark (Standalone) ----
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=8181
SPARK_WORKER_UI_PORT=8182

# ---- API ключи ----
# Получи на https://www.api-football.com (free tier 100 req/day)
API_FOOTBALL_KEY=